# Server configuration
QR_HOST=0.0.0.0
QR_PORT=8080
QR_WORKERS=1
QR_RELOAD=false
QR_LOG_LEVEL=INFO

# Request handling
QR_REQUEST_TIMEOUT=10.0
QR_MAX_CONTENT_LENGTH=2048
QR_RATE_LIMIT=10/minute
QR_CORS_ORIGINS=

# QR styling
QR_QR_FILL_COLOR=#1e3a8a
QR_QR_BACK_COLOR=#ffffff
QR_QR_MODULE_ROUND=0.4
QR_QR_BOX_SIZE=12
QR_QR_BORDER=4
